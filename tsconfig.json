{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",

		"lib": ["ESNext", "DOM"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",

		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,

		"verbatimModuleSyntax": true,
		"isolatedModules": true
	},
	"exclude": ["./drizzle.config.ts"]
}
