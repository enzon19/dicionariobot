{
	"compilerOptions": {
		"lib": ["ESNext"],
		"target": "ESNext",
		"rootDir": "./src",
		"outDir": "./dist",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"skipLibCheck": true
	},
	"exclude": ["./drizzle.config.ts"]
}
